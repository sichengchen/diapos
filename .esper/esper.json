{
  "schema_version": 1,
  "backlog_mode": "local",
  "spec_root": "specs",
  "commands": {
    "test": "bun run test",
    "lint": "bun run lint",
    "typecheck": "bun run typecheck",
    "dev": "bun run dev"
  },
  "workflow_defaults": {
    "work_mode": "atom",
    "commit_granularity": "milestone",
    "pr_policy": "auto-per-increment",
    "validation": "blocking",
    "spec_sync": "proactive"
  }
}
