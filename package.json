{
  "name": "diapos-workspace",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "bun run --filter diapos build",
    "build:demo": "vite build",
    "deploy": "vite build && wrangler deploy",
    "bump": "npm version --no-git-tag-version --workspaces --include-workspace-root",
    "copy:readme": "cp README.md packages/diapos/README.md && cp README.md packages/create-diapos/README.md",
    "publish:all": "bun run copy:readme && npm publish --workspace packages/diapos --access public && npm publish --workspace packages/create-diapos --access public",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  }
}
