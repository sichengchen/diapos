{
  "name": "diapos",
  "version": "0.0.3",
  "type": "module",
  "main": "./dist/diapos.js",
  "module": "./dist/diapos.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/diapos.js",
      "types": "./dist/index.d.ts"
    },
    "./themes/geneva": {
      "import": "./dist/themes/geneva.js",
      "types": "./dist/themes/geneva.d.ts"
    },
    "./themes/milan": {
      "import": "./dist/themes/milan.js",
      "types": "./dist/themes/milan.d.ts"
    },
    "./themes/vienna": {
      "import": "./dist/themes/vienna.js",
      "types": "./dist/themes/vienna.d.ts"
    },
    "./styles.css": "./dist/diapos.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -b --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}
